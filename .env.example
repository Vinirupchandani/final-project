# Copy to .env.local and fill in values. Never commit .env.local.

# --- Required for full app behavior ---
# OpenAI: caption extraction, embeddings, recommendation reranking
OPENAI_API_KEY=

# Google Places API (New) — enable "Places API (New)" on your GCP project
# https://developers.google.com/maps/documentation/places/web-service/op-overview
GOOGLE_PLACES_API_KEY=

# --- Supabase (if using DB features) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional ---
FOURSQUARE_API_KEY=
